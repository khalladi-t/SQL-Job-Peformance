# Create the Windows login if it does not exist
IF NOT EXISTS (SELECT 1 FROM sys.server_principals WHERE name = N'<username>')
    CREATE LOGIN [<username>] FROM WINDOWS;
GO

-- Ensure it is enabled
ALTER LOGIN [<username>] ENABLE;
GO

-- Set a safe default database
ALTER LOGIN [<username>] WITH DEFAULT_DATABASE = [master];
GO

-- Temporarily make sysadmin so you can fix everything else in SSMS
EXEC sp_addsrvrolemember N'<username>', N'sysadmin';
GO

QUIT
